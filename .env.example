# =============================================================================
# 사용법: cp .env.example .env  후 아래 [필수]만 채우면 로컬 기동 가능.
#   - docker compose: backend 컨테이너가 이 .env 전체를 env_file로 주입받는다.
#   - 로컬 uvicorn: python-dotenv가 .env를 로드한다 (시스템 환경변수가 있으면 그게 우선).
# [필수] OPENAI_API_KEY, JWT_SECRET  나머지는 기본값으로 동작.
# =============================================================================
APP_ENV=development
APP_PORT=8000                        # docker-compose 포트 매핑 전용 (앱 코드는 안 읽음)
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Vercel 프리뷰 배포는 URL에 해시가 붙어 매번 달라진다 — 정규식으로 한 번에 허용한다.
# 미설정 시 기본값(a360-assistant-frontend-*-a360-assistant.vercel.app)이 쓰인다.
# ⚠️ CORS 허용 범위다 — 넓히면 아무 오리진이나 인증 쿠키/토큰을 실어 부를 수 있다.
# FRONTEND_ORIGIN_REGEX=https://a360-assistant-frontend-.*-a360-assistant\.vercel\.app
OPENAI_API_KEY=                      # [필수] LLM·임베딩
DATABASE_HOST=localhost              # 호스트 CLI/로컬 uvicorn용. 컨테이너 안에서는 compose가 db로 덮어씀
DATABASE_PORT=5432                   # 로컬 5432 점유 시 5433 (컨테이너 내부 접속과는 무관)
DATABASE_NAME=a360
DATABASE_USERNAME=a360_admin
DATABASE_PASSWORD=a360_local_password

# --- 공유 앱 DB 토글 (RPA-186) ---
# 설정하면 위 DATABASE_* 조각을 **통째로** 대체해 팀 공유 Postgres(Neon 등)에 붙는다.
# 계정·세션·대화 이력·추천을 팀이 실시간으로 공유한다. **미설정이 기본** = 로컬 단독(기존 동작).
# 목적: 관측 DB의 session_id ↔ 실제 대화 내용 조인(각자 로컬이면 백오피스에서 대화를 못 본다).
# Neon 콘솔의 postgresql:// 문자열을 그대로 붙여넣으면 된다(psycopg 드라이버로 자동 변환).
# 크레덴셜 커밋 금지!
#
# ⚠️ **Alembic** — 이 토글이 켜져 있으면 앱 기동 시 **자동 마이그레이션이 꺼진다**(경고만 남김).
#    공유 DB는 alembic_version이 팀 전체에 하나뿐이라, 서버 띄울 때마다 각자 브랜치 head로
#    자동 적용되면 head가 둘이 되어 전원 기동 불가가 된다. 그래서 코드로 막는다.
#    → dev 머지 후 **한 명이** 명시적으로: python scripts/migrate_shared_db.py --apply
#    → **스키마를 만드는 중엔 이 토글을 끄고 로컬**에서 작업한다(로컬은 자동 적용이라 평소대로).
#    자세한 건 docs/CONVENTIONS.md §7.
#
# ⚠️ **공유 DB에 pytest 금지.** tests/conftest.py가 이 값을 import 전에 **빈 문자열로 덮어써**
#    로컬로 강제하고 (pop이면 안 된다 — load_dotenv()가 .env에서 되살린다)
#    (_assert_app_db_is_local이 fail-closed로 확인), live 기동은 manage.ps1이 검사한다.
#    TRUNCATE·리셋 금지 — 팀원이 실시간으로 쓴다.
# APP_DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.ap-northeast-2.aws.neon.tech/neondb?sslmode=require
OPENSEARCH_HOST=http://localhost:9200
OPENSEARCH_PORT=9200                 # docker-compose 포트 매핑 전용 (앱 코드는 안 읽음)
OPENSEARCH_INDEX=rag_documents
# OPENSEARCH_USERNAME=               # 보안 켜진 OpenSearch에 붙을 때만 (로컬 compose는 보안 비활성)
# OPENSEARCH_PASSWORD=
DOCUMENT_BUCKET=
# LOGS_BUCKET 제거 (RPA-189 감사) — infra/a360-backend-private.yml이 컨테이너에 주입하지만
#   앱 코드가 **읽는 곳이 0곳**이었다. 죽은 config는 '있으니 동작하겠지'라는 오해를 만든다.
#   S3 로그 업로드를 실제로 붙일 때 infra와 함께 되살릴 것.
PDFBOX_JAR_PATH=/opt/pdfbox/pdfbox-app.jar
# LIBREOFFICE_PATH=                  # 레거시 .ppt 변환용 soffice 경로 (미설정 시 PATH에서 자동 탐지)

# --- 인증 (app/api/auth) ---
# [필수] JWT 서명 시크릿 — 미설정 시 앱 기동 거부. (manage.ps1이 .env 생성 시 자동 발급)
# 직접 만들려면: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=60
# 갱신 토큰 수명 (RPA-200) — 이 기간 안에는 재로그인 없이 /api/auth/refresh로 이어간다.
# ⚠️ 이 값이 곧 **탈취 시 최대 노출 기간**이다 — 갱신 토큰을 쥔 공격자는 만료 전까지 계속
# 새 액세스 토큰을 받아낼 수 있다. 회전(1회용)·재사용 탐지는 **정상 사용자가 다시 갱신을
# 시도한 뒤에야** 발동하므로(그때 계열 전체 폐기), 탐지 전까지의 창은 닫히지 않는다.
# 길게 잡을수록 편의는 오르고 노출은 커진다 — 늘릴 땐 그 트레이드오프를 알고 늘릴 것.
REFRESH_TOKEN_EXPIRE_DAYS=14
# 갱신 토큰 쿠키의 Secure 여부 (RPA-216). 기본 true = 운영 기준.
#   true  → Secure + SameSite=None : 프론트(Vercel)와 백엔드가 다른 도메인(cross-site)일 때 필요
#   false → Secure 없음 + SameSite=Lax : 로컬 http(localhost↔localhost)는 same-site라 이걸로 전달된다
# ⚠️ 기본을 true로 둔 이유는 **빠뜨렸을 때 로컬이 불편한 쪽**이 **운영 보안이 조용히 꺼지는 쪽**보다
#    낫기 때문이다. 로컬에서만 false로 내려 쓸 것. 운영에 false를 넣으면 갱신 토큰이 평문 http로 나간다.
# ⚠️ Secure 없는 SameSite=None은 브라우저가 거부하므로 두 값은 이 토글로 함께 정해진다.
SECURE_COOKIES=true

# 관리 API(/api/admin/*) 접근 제어 (RPA-118) — 두 경로:
#  ① 사람 관리자: 아래 ADMIN_EMAILS는 '부트스트랩 시드' — 여기 이메일로 가입/기동 시
#     users.is_admin=True로 승격된다. 실제 인가 판정은 문자열이 아니라 is_admin 속성.
#     미설정 시 승격 없음(전부 비관리자, fail-closed).
# ADMIN_EMAILS=admin@example.com,ops@example.com
#  ② 서비스(M2M): ops-server 등 머신은 사람 로그인을 재사용하지 않고 이 키를 X-API-Key
#     헤더로 보낸다. 미설정/빈값이면 키 경로 비활성(fail-closed). 강한 난수로 생성:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
# OPS_API_KEY=

# Change Assurance 판정 기록 전용 writer (RPA-207).
# 일반 관리자·백오피스 키와 분리한다. GitHub의 보호된 workflow_run publisher만 이 값을 가지고
# Authorization: Bearer로 /api/internal/assurance/change-receipts를 호출한다.
# 미설정이면 쓰기 경로는 503으로 fail-closed하며 기존 PR Observe·조회 기능은 그대로 동작한다.
# 강한 난수로 생성하고 GitHub protected environment와 Backend 런타임에만 각각 저장한다.
# Format: 32-128 Base64URL characters without padding ([A-Za-z0-9_-]).
# ASSURANCE_WRITER_TOKEN=
# 이 writer가 수용할 단일 GitHub 저장소. 예: Metanet-Final-01/A360-Assistant-Backend
# ASSURANCE_WRITER_REPOSITORY=

# --- 관측 전용 공유 DB (RPA-90) ---
# audit_logs·llm_usage를 전용 Postgres로 보내 비용·감사를 한 곳에 집계한다.
# 필수: 미설정 시 관측 기능은 unavailable이며 앱 DB로 대신 기록하지 않는다.
# Neon은 앱 접속에 pooled 커넥션 스트링(-pooler 호스트)을 쓴다. 크레덴셜 커밋 금지!
OBSERVABILITY_DATABASE_URL=postgresql+psycopg://a360_admin:a360_local_password@localhost:5432/a360_observability
# Compose에서 다른 관측 DB를 명시할 때만 사용(일반 OBSERVABILITY_DATABASE_URL과 분리).
# LOCAL_OBSERVABILITY_DATABASE_URL=postgresql+psycopg://user:pass@db:5432/a360_observability

# --- 일별 롤업 배치 (RPA-104, APScheduler) ---
# request_metrics→metrics_daily, llm_usage→usage_daily 멱등 재집계 + raw retention.
# METRICS_ROLLUP_ENABLED=true     # false면 스케줄러 안 켬
# ROLLUP_INTERVAL_MINUTES=60      # 재집계 주기(오늘+어제, 멱등이라 안전)
# 테이블별 raw 보관 일수(RPA-123, 0=영구). 성격별로 다르게 — 근거는 docs/관측_운영_정책.md.
# METRICS_RETENTION_DAYS=30       # request_metrics (metrics_daily 집계본 있음)
# TURN_EVENTS_RETENTION_DAYS=30   # turn_events (고volume 디버그 타임라인)
# LLM_USAGE_RETENTION_DAYS=90     # llm_usage (usage_daily 집계본 있음, 비용 재조회 여지)
# AUDIT_RETENTION_DAYS=365        # audit_logs (forensic — 길게 보관, 0=영구)

# LLM 예산 가드레일 (RPA-171) — 턴 진입 시 llm_usage 누적 비용을 검사해 초과면 429로 막는다.
# 일/월 경계는 **KST 자정**(app/core/localtime) — 일별 집계(rollup)·당일 알림(alerts)과 같은 축이다.
#   UTC 자정이었을 때는 일 상한이 한국시간 오전 9시에 리셋되고 KST 0~9시 지출이 '어제'로 묶였다.
#   ⚠️ 아래 실측 임계는 UTC 창 기준으로 산출된 값이다 — KST 전환·cached_tokens 반영 후 재산출할 것.
# **미설정=비활성**(기존 동작 그대로). 하나라도 설정하면 그 상한만 적용된다.
# 주체 = 로그인이면 user_id, 익명이면 session_id (/turn이 익명을 허용하므로 익명도 덮는다).
# 관측이 "보기"에서 "막기"로 넘어가는 지점 — 기성 APM(Datadog)은 대시보드·알림만 주고
# 요청을 막거나 계층적 예산을 적용하지 않는다. 근거·설계는 docs/관측_운영_정책.md.
# ⚠️ 아래 5개는 import 시점에 읽는 "기본값/폴백"이다 — 변경하려면 재배포 필요.
#    무중단 조정은 admin API(PUT /api/admin/budget-limits)로 DB 오버라이드 (RPA-173).
#    DB 오버라이드 행이 있으면 그 값이 **통째로** 우선, 없으면 아래 .env 값으로 폴백한다.
# ⚠️ 아래 값은 **실측 기반**이다 — 감으로 정하지 말 것. 트래픽이 쌓이면 재산출한다:
#      python scripts/budget_calibration_report.py
#    2026-07-15 표본(llm_usage 6,237행 / 6일 / 사용자 31명 / 세션 178개, cost_usd 백필 후) 기준:
#      사용자-일 최대 $2.02, 전역-일 최대 $5.04, 30일 환산 $72.74 → 여유 2.5배로 아래 값.
#    (최초 구현 때 감으로 쓴 $1/일은 실측 최대 $2.02보다 낮아, 켰다면 정상 사용자를 막았을 값)
# BUDGET_SUBJECT_DAILY_USD=6      # 주체별 일 상한 (chargeback — "누가 얼마 썼나")
# BUDGET_SUBJECT_MONTHLY_USD=120  # 주체별 월 상한 (일 상한 × 영업일 20)
# BUDGET_GLOBAL_DAILY_USD=45      # 전역 일 상한 (OpenAI 청구서 보호 — DoW 방어). 회로 차단기다.
#   ⚠️ 15였다가 45로 정정 (RPA-189) — 실측 완결일 최대가 $17.81(07-15)로 **권장값보다 높았다**.
#   그대로 켰으면 바쁜 날 팀 전체가 막혔다. 원인: 캘리브레이션을 그날 오후에 돌려 **아직 안 끝난
#   당일**을 포함했고(그 시점 누적 $12~13), 그걸 '일 최대'로 읽었다. 리포트는 완결일만 볼 것.
#   일상 감시는 아래 ALERT_GLOBAL_DAILY_USD(알림)가 맡는다 — 알림은 일찍, 차단은 늦게.
# BUDGET_GLOBAL_MONTHLY_USD=300   # 전역 월 상한

# --- Slack 알림 (RPA-189) — meter → enforce → **alert**
# 수집(llm_usage·request_metrics·rag_events)도 통제(429 차단)도 있는데 **아무도 안 알렸다**.
# 예산을 넘겨 사용자를 막아도 대시보드를 열어봐야만 알았다. 그 마지막 한 걸음.
# **미설정=비활성** — 없으면 아무것도 안 한다(로컬·CI 기존 동작 그대로). 켜는 건 배포 인스턴스.
# 발급: api.slack.com/apps → Create New App → Incoming Webhooks → Add New Webhook
# ⚠️ 이 URL을 아는 사람은 누구나 그 채널에 글을 쓸 수 있다 — 크레덴셜이다. 커밋 금지.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<팀ID>/<앱ID>/<토큰>
#   ↑ 자리표시자다. 진짜 형태(T…/B…/24자)로 예시를 적으면 **GitHub Push Protection이
#     가짜와 진짜를 구분 못 해 푸시를 막는다** — 실제로 이 커밋이 한 번 거절당했다.
#
# 같은 사유가 이어질 때 재알림 주기(분). 0이면 전이(ok↔firing) 때만 알린다.
# 상태는 alert_state 테이블(관측 DB)에 남는다 — 인메모리면 재시작·워커마다 중복 발송이다.
# ALERT_COOLDOWN_MINUTES=60
#
# ⚠️ 아래 임계도 **실측 기반**이다 (2026-07-16, 완결일만 집계 — 당일은 아직 안 끝났다):
#   전역 일 비용: 최대 $17.81(07-15) / 그 외 $1~5   → 알림 15(자주 있는 일 아님), 차단 45
#   5xx: **6일간 총 1건**(0.1%) → 1건만 나도 이상하다. 3이면 확실히 이상.
#   4xx는 2.2~23%로 튄다(테스트 401/404) → **알림 대상 아님**. 켜면 상시 울려 무시당한다.
# ALERT_GLOBAL_DAILY_USD=15       # 전역 일 비용 알림 (차단 BUDGET_GLOBAL_DAILY_USD=45보다 낮게)
# ALERT_5XX_DAILY=3               # 5xx 일 건수
#
# 헬스 감시 주기(분) — /health를 찔러 degraded/unhealthy 전이 시 알린다.
# 롤업(60분)과 분리한 이유: 의존성이 죽은 걸 1시간 뒤에 알면 늦다. 너무 잦으면 DB·OpenSearch를
# 쓸데없이 찌른다 — 기본 5분. **스케줄러 등록 시점에 읽으므로 변경하려면 재시작**이 필요하다.
# ⚠️ 앱이 죽으면 이 잡도 죽는다 — 프로세스 다운은 **자기가 못 알린다**. 그건 앱 밖(백오피스
#    프로브)에서 봐야 한다. 여기가 잡는 건 '앱은 살아있고 의존성이 죽은' degraded다.
# ALERT_HEALTH_INTERVAL_MINUTES=5

# 디버그 엔드포인트(/api/rag/debug/*, /debug 콘솔) — APP_ENV=production이면 기본 차단.
# 프로덕션에서 강제로 열려면 DEBUG_ENDPOINTS_ENABLED=true (권장하지 않음).
# DEBUG_ENDPOINTS_ENABLED=true
# 디버그 HTTP 프록시 — 위 게이트에 더해 이 값까지 true여야 동작 (로컬 전용, 배포엔 설정 금지)
DEBUG_HTTP_CLIENT_ENABLED=true

# --- 문서 업로드 (app/api/documents) ---
# DOCUMENT_BUCKET이 비어 있으면 UPLOAD_DIR(로컬 디스크)에 저장한다
UPLOAD_DIR=data/uploads
MAX_UPLOAD_MB=20

# --- 비전 파싱 (FR-03, app/services/parser/vision.py) ---
# VISION_MODEL=            # 미설정 시 OPENAI_MODEL 사용
VISION_MIN_TEXT_CHARS=200  # 페이지 텍스트가 이 값 미만이면 비전 보강 대상
VISION_MAX_PAGES=15        # 문서당 비전 호출 페이지 상한 (비용 가드)
VISION_CONCURRENCY=4       # 페이지 비전 호출 병렬 수
VISION_FORCE_EMPTY_CHARS=50  # PDF: 이미지 없는 페이지도 실질 텍스트가 이 값 미만이면 비전 대상

# --- LLM 비용 기록 (app/core/llm.py) — USD per 1M tokens, 설정 시 llm_usage.cost_usd 계산 ---
# 아래는 주 챗 모델(OPENAI_MODEL) 단가. 미설정 시 챗 모델 비용은 null로 남는다.
# gpt-5.4-mini 공식 단가(developers.openai.com, 2026-07): input $0.75 / output $4.50 per 1M
LLM_INPUT_COST_PER_1M=0.75
LLM_OUTPUT_COST_PER_1M=4.50
# 캐시된 입력 단가 (RPA-199) — gpt-5.4-mini cached input $0.075 per 1M (정가의 10%).
# 미설정이면 캐시분도 전액으로 계산된다(구 동작) — 실측에서 이게 4.7배 과대계상의 주원인이었다
# (turn_generate가 평균 입력 9,349토큰의 프롬프트를 턴마다 반복 → 대부분 캐시 적중).
LLM_CACHED_INPUT_COST_PER_1M=0.075
# --- LLM 호출 시간 상한 (RPA-202) ---
# 미설정 시 SDK 기본이 read 600초(10분)라, 응답이 안 오면 요청 하나가 10분간 워커를 붙잡는다.
# 아래 기본값은 실측 근거: 관측 DB llm_usage 챗 5,441콜에서
#   turn_generate p50 3.5초 / p95 34초 / p99 73초 / 최대 152초
# 처음 잡으려던 60초는 정상 요청을 잘랐을 값이다(p99 73초). 관측 최대에 여유를 둬 180초.
# LLM_TIMEOUT_SECONDS=180          # read 타임아웃
# LLM_CONNECT_TIMEOUT_SECONDS=5    # 연결은 짧게 — 안 붙는 상황은 기다릴 이유가 없다
# LLM_MAX_RETRIES=2                # SDK 기본과 동일. 대상: 408·409·429·5xx·연결오류
# 임베딩·리랭커(text-embedding-3-small, rerank-2.5-lite 등)는 위 env와 무관하게
# app/core/llm.py의 내장 단가 테이블(_AUX_MODEL_PRICES)로 자동 계산된다 (RPA-97).

# --- RAG 저장소 전용 공유 DB (RPA-132) ---
# RAG 코퍼스(pgvector rag_documents)를 앱 DB와 분리된 전용 DB에 둔다.
# 필수: 미설정 시 앱 DB로 폴백하지 않고 기동을 거부한다.
# ⚠️ RAG store는 raw psycopg라 libpq URL(postgresql://) 형식. sslmode=require 포함, -pooler 호스트 사용.
#    (SQLAlchemy용 'postgresql+psycopg://'를 붙여도 자동으로 벗겨 동작하나 postgresql://가 정석)
# ⚠️ 팀 공유 시 EMBEDDING_PROVIDER/MODEL/DIM을 전원 동일하게 + 적재(ingest) 때 쓴 값과 일치시킬 것
#    (불일치 시 차원 오류·엉뚱한 벡터공간으로 검색이 깨진다). 크레덴셜 커밋 금지!
RAG_DATABASE_URL=postgresql://a360_admin:a360_local_password@localhost:5432/a360_rag
# Compose에서 다른 RAG DB를 명시할 때만 사용(일반 RAG_DATABASE_URL과 분리).
# LOCAL_RAG_DATABASE_URL=postgresql://user:pass@db:5432/a360_rag

# --- RAG 수집 파이프라인 (app/rag) ---
# 임베딩: openai 또는 voyage. Anthropic은 임베딩 API가 없어 별도 provider 사용.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
# VOYAGE_API_KEY=                    # EMBEDDING_PROVIDER=voyage 또는 리랭커 사용 시 필요
# AA_DOCS_BASE_URL=                  # A360 공식 문서(Fluid Topics) 크롤링 베이스 (미설정 시 기본값)
# INGEST_DATA_DIR=                   # 수집 산출물 디렉터리 (기본 data/ingest)
# RAG_LOG_DIR=                       # 파이프라인 로그 디렉터리 (기본 app/rag/logs)
CHUNK_SIZE=1200                      # 청킹 크기 (EDA로 검증된 기본값)
CHUNK_OVERLAP=200

# 하이브리드 검색(RRF) + Voyage Reranker (VOYAGE_API_KEY 필요, 없으면 RRF 순서 그대로 반환)
# ⚠️ 아래 5개는 import 시점에 고정되는 "기본값/폴백"이다 — 변경하려면 재시작 필요.
#    무중단 튜닝은 admin API(PUT /api/admin/retrieval-params)로 DB 오버라이드 (RPA-149).
#    DB 오버라이드가 있으면 그 값이 우선, 없으면 아래 .env 값으로 폴백한다.
RRF_K=60
HYBRID_CANDIDATE_POOL_SIZE=50
HYBRID_RERANK_CANDIDATES=20
RRF_VECTOR_WEIGHT=1.0                 # RRF 벡터(의미) branch 가중치 — 키우면 의미검색 비중↑
RRF_BM25_WEIGHT=1.0                   # RRF BM25(키워드) branch 가중치 — 키우면 키워드매칭 비중↑
RERANK_MODEL=rerank-2.5-lite

# Control Room 봇 수집 (선택 — 회사 Control Room 봇을 수집할 때만)
CR_URL=
CR_USERNAME=
CR_PASSWORD=
# CR_API_KEY=

# GitHub 공개 봇/패키지 수집 (선택 — 없으면 시간당 60회 제한, 있으면 5000회)
GITHUB_TOKEN=

# --- Agent 오케스트레이터 (app/agent) ---
# 에이전트가 호출하는 OpenAI 챗 모델 (미설정 시 gpt-5.4-mini). API 키는 위 OPENAI_API_KEY 사용.
OPENAI_MODEL=gpt-5.4-mini
# 요청에 agent_version이 없을 때의 기본 에이전트 버전 (미설정 시 v2). app/agent/vN 폴더로 발견되는 버전만 유효 (RPA-167).
# AGENT_VERSION=v2
# 검색기·카탈로그는 항상 실제 RAG(HybridRetriever/BackendCatalog)를 쓴다 —
# pgvector·OpenSearch·rag_documents 인프라가 필요하다. 유닛 테스트는 conftest가 인메모리 스텁을 주입한다.
# 그래프 전체 동시 LLM 호출 상한 (rate limit 방어, 기본 3). 배포 환경 rate limit에 맞춰 조정.
# MAX_LLM_CONCURRENCY=3

# 대화 누적 게이지 임계(토큰) — intake 프롬프트가 이 값 대비 WARN_RATIO 넘으면 compact 권장 (RPA-83)
# ✅ 실측 재보정 완료 (RPA-172, 2026-07-15) — 기본값 100000 → 6000. 이전 값은 하드 도달에
#    ~527턴이 필요해 자동 compact가 절대 발동하지 않았다(RPA-89가 진단만 해둔 상태였음).
#    실측(관측 DB 6,237행): 누적 Δ≈188토큰/턴, 첫 턴 base≈582, 세션당 중앙 1턴·최대 7턴.
#    6000 근거: 현실 입력의 최악 = base(582) + 한글 4,000자(≈1.08 tok/char → 4,309) = 4,891이라
#    그 아래면 평범한 긴 한국어 입력만으로 초반 오발동 / 6000이면 compact 비용($0.00843/콜)이
#    2턴이면 본전(3000은 5턴).
#    ⚠️ max_length=4000은 **문자** 상한이지 토큰 상한이 아니다(둘을 혼동해 한때 4,772로 적었음).
#       cl100k_base 실측 tok/char: 영문 0.12 / 한글 1.08 / 희귀 CJK 2.0 / 이모지 3.0 → 같은
#       4,000자가 500~12,000토큰. 이 값을 재산출할 땐 문자가 아니라 토큰으로 계산할 것.
#    ✅ live 검증 완료 (RPA-172 후속): 4턴째 자동 compact 발동, intake 4,574→2,863(~37% 감소).
#    ⚠️ "하드 29턴"은 짧은 메시지(Δ=188) 기준이다. **긴 메시지를 쓰면 4턴이면 터진다** —
#       발동 시점은 턴 수가 아니라 **입력 길이**가 지배한다(live 실측).
#    ⚠️ 표본이 테스트·시뮬 트래픽 위주다. 실사용 대화가 쌓이면 재산출:
#       python scripts/gauge_calibration_report.py
# TURN_GAUGE_LIMIT_TOKENS=6000
# compact 권장(소프트) 임계 비율 — 기본 0.87 (RPA-172 재보정, 이전 0.7).
#   LIMIT=6000에서 "하드 4턴 전 경고" = 1 − 4×188/6000 ≈ 0.87. 0.7이면 10턴 전부터 알림이 뜬다.
# TURN_GAUGE_WARN_RATIO=0.87
# 이 비율 이상이면 백엔드가 실제 턴 전에 자동 compact 실행 (RPA-84).
# TURN_GAUGE_HARD_RATIO=1.0
# --- RAG 캐싱 2층 (RPA-211) — 질의 임베딩 + 검색 결과 ---
# **미설정=비활성**(기존 동작 그대로). 켜는 건 배포 인스턴스.
# 근거(실측): 턴 시간의 68%가 RAG(41.9초/61.9초), RAG 5.5초 중 74%가 외부 API 왕복
#   (임베딩 1,991ms 36% + 리랭커 2,068ms 38%). 적중 시 5.5초 → 0.1ms.
# ⚠️ TTL 주의: 적재(ingest)는 **별도 프로세스**라 이 캐시를 못 비운다. 코퍼스가 바뀌면
#   최대 TTL 동안 옛 결과가 나갈 수 있어 기본을 1시간으로 짧게 잡았다.
#   실측 적중률: 5분 6% / 60분 13% / 24시간 24% — 길게 잡을수록 적중은 오르고 낡을 위험도 커진다.
#   적재 직후 데모라면 서버를 재기동할 것.
# RAG_CACHE_ENABLED=true
# RAG_CACHE_TTL_SECONDS=3600
# RAG_CACHE_MAXSIZE=2048
