{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:a360:assurance:change-manifest:1.0",
  "title": "A360 Change Assurance derived manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "subject",
    "changes",
    "risk_profiles",
    "applicable_controls",
    "policy"
  ],
  "$defs": {
    "sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  },
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "base_sha",
        "merge_base_sha",
        "head_sha",
        "diff_sha256"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "base_sha": {
          "$ref": "#/$defs/sha"
        },
        "merge_base_sha": {
          "$ref": "#/$defs/sha"
        },
        "head_sha": {
          "$ref": "#/$defs/sha"
        },
        "diff_sha256": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "path"
        ],
        "properties": {
          "status": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "old_path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "risk_profiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "applicable_controls": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^CH-[0-9]{2}$"
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri",
        "sha256",
        "rollout_mode",
        "decision_state"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/digest"
        },
        "rollout_mode": {
          "const": "observe"
        },
        "decision_state": {
          "enum": [
            "decision_needed",
            "approved",
            "approved_fixture"
          ]
        }
      }
    }
  }
}
