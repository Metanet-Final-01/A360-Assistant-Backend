{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:a360:assurance:change-report:1.0",
  "title": "A360 Change Assurance Observe report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "subject",
    "environment",
    "manifest_evidence",
    "controls",
    "evidence_complete",
    "assurance_decision",
    "business_outcome",
    "enforcement"
  ],
  "$defs": {
    "sha": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        {
          "const": "unknown"
        }
      ]
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri",
        "sha256",
        "subject_sha"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/digest"
        },
        "subject_sha": {
          "$ref": "#/$defs/sha"
        }
      }
    }
  },
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "pattern": "^CA-[0-9a-f]{16}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "base_sha",
        "head_sha"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "base_sha": {
          "$ref": "#/$defs/sha"
        },
        "head_sha": {
          "$ref": "#/$defs/sha"
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python_version",
        "python_implementation",
        "os",
        "platform",
        "dependency_sha256",
        "git_version"
      ],
      "properties": {
        "python_version": {
          "type": "string",
          "minLength": 1
        },
        "python_implementation": {
          "type": "string",
          "minLength": 1
        },
        "os": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "dependency_sha256": {
          "$ref": "#/$defs/digest"
        },
        "git_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "manifest_evidence": {
      "oneOf": [
        {
          "$ref": "#/$defs/evidence"
        },
        {
          "type": "null"
        }
      ]
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "control_id",
          "status",
          "reason_code",
          "reason",
          "evidence"
        ],
        "properties": {
          "control_id": {
            "type": "string",
            "pattern": "^CH-[0-9]{2}$"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "error",
              "unassured",
              "not_applicable"
            ]
          },
          "reason_code": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "$ref": "#/$defs/evidence"
          }
        }
      }
    },
    "evidence_complete": {
      "type": "boolean"
    },
    "assurance_decision": {
      "enum": [
        "allow_candidate",
        "deny",
        "unassured"
      ]
    },
    "business_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "changed_by_assurance"
      ],
      "properties": {
        "decision": {
          "const": "not_evaluated"
        },
        "changed_by_assurance": {
          "const": false
        }
      }
    },
    "enforcement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "blocks_merge"
      ],
      "properties": {
        "mode": {
          "const": "observe"
        },
        "blocks_merge": {
          "const": false
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "assurance_decision": {
            "const": "allow_candidate"
          }
        },
        "required": [
          "assurance_decision"
        ]
      },
      "then": {
        "properties": {
          "evidence_complete": {
            "const": true
          },
          "manifest_evidence": {
            "$ref": "#/$defs/evidence"
          },
          "subject": {
            "properties": {
              "base_sha": {
                "type": "string",
                "pattern": "^[0-9a-f]{40}$"
              },
              "head_sha": {
                "type": "string",
                "pattern": "^[0-9a-f]{40}$"
              }
            }
          },
          "controls": {
            "not": {
              "contains": {
                "properties": {
                  "status": {
                    "enum": [
                      "fail",
                      "error",
                      "unassured"
                    ]
                  }
                },
                "required": [
                  "status"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "assurance_decision": {
            "const": "deny"
          }
        },
        "required": [
          "assurance_decision"
        ]
      },
      "then": {
        "properties": {
          "controls": {
            "contains": {
              "properties": {
                "status": {
                  "const": "fail"
                }
              },
              "required": [
                "status"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "assurance_decision": {
            "const": "unassured"
          }
        },
        "required": [
          "assurance_decision"
        ]
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "evidence_complete": {
                "const": false
              }
            }
          },
          {
            "properties": {
              "controls": {
                "contains": {
                  "properties": {
                    "status": {
                      "enum": [
                        "error",
                        "unassured"
                      ]
                    }
                  },
                  "required": [
                    "status"
                  ]
                }
              }
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "manifest_evidence": {
            "type": "null"
          }
        },
        "required": [
          "manifest_evidence"
        ]
      },
      "then": {
        "properties": {
          "evidence_complete": {
            "const": false
          },
          "assurance_decision": {
            "const": "unassured"
          }
        }
      }
    }
  ]
}
