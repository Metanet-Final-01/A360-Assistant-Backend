{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:a360:harness:schema:assurance-report:1.8",
  "title": "Assurance Report (Change Assurance)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run",
    "subject",
    "trusted_context",
    "runtime_env",
    "manifest_binding",
    "derived_facts",
    "control_registry_digest",
    "schema_digest",
    "gates",
    "verdict"
  ],
  "$defs": {
    "control_id": {
      "type": "string",
      "pattern": "^(CH|OH|EH)-[0-9]{2}$"
    },
    "git_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri",
        "type",
        "digest"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "junit",
            "sarif",
            "jsonl",
            "db_row",
            "http_response",
            "log",
            "report",
            "sbom",
            "diff"
          ]
        },
        "digest": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  },
  "properties": {
    "schema_version": {
      "const": "1.8"
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "started_at",
        "ended_at",
        "git_state"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time"
        },
        "git_state": {
          "enum": [
            "clean",
            "dirty"
          ]
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "version"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_id",
        "commit"
      ],
      "properties": {
        "repository_id": {
          "type": "string",
          "minLength": 1
        },
        "repository_name": {
          "type": "string"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "image_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "manifest_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "change_manifest_digest",
        "manifest_repository_id",
        "manifest_baseline_sha",
        "manifest_head_sha"
      ],
      "description": "P0-2: the report copies the manifest identity it claims to cover. HL-12 recomputes the digest from the real manifest bytes and requires subject.repository/commit == manifest repository/head_sha.",
      "properties": {
        "change_manifest_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$",
          "description": "Recomputed by the trusted runner from the read-once manifest artifact."
        },
        "manifest_repository_id": {
          "type": "string",
          "minLength": 1
        },
        "manifest_baseline_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "manifest_head_sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        }
      }
    },
    "derived_facts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "derivation_tool",
        "derivation_version",
        "dependency_path_policy_digest",
        "repository_id",
        "diff_baseline_sha",
        "diff_head_sha",
        "changed_paths",
        "dependency_changed",
        "silent_install_hits",
        "touches_agent_owned_paths",
        "risk_profiles",
        "applicable_controls",
        "git_state",
        "applicability_policy_digest",
        "unreadable_scanned_paths"
      ],
      "description": "P0-1: values the ATTESTOR derived from the actual diff. HL-11 recomputes these and compares them to the manifest's declared_* claims; any mismatch fails closed.",
      "properties": {
        "derivation_tool": {
          "type": "string",
          "minLength": 1
        },
        "derivation_version": {
          "type": "string",
          "minLength": 1
        },
        "dependency_path_policy_digest": {
          "$ref": "#/$defs/sha256"
        },
        "diff_baseline_sha": {
          "$ref": "#/$defs/git_sha"
        },
        "diff_head_sha": {
          "$ref": "#/$defs/git_sha"
        },
        "changed_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dependency_changed": {
          "type": "boolean"
        },
        "touches_agent_owned_paths": {
          "type": "boolean"
        },
        "risk_profiles": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "applicable_controls": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/control_id"
          }
        },
        "declaration_mismatches": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Non-empty means the author's manifest claims disagree with the real diff."
        },
        "repository_id": {
          "type": "string",
          "minLength": 1
        },
        "git_state": {
          "enum": [
            "clean",
            "dirty"
          ]
        },
        "silent_install_hits": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "applicability_policy_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "unreadable_scanned_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "control_registry_digest": {
      "$ref": "#/$defs/sha256"
    },
    "schema_digest": {
      "$ref": "#/$defs/sha256"
    },
    "runtime_env": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python_version",
        "os",
        "dependency_digest"
      ],
      "properties": {
        "python_version": {
          "type": "string",
          "minLength": 1
        },
        "os": {
          "type": "string",
          "minLength": 1
        },
        "dependency_digest": {
          "$ref": "#/$defs/sha256"
        },
        "validator_library": {
          "type": "string"
        }
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "control_id",
          "status"
        ],
        "properties": {
          "control_id": {
            "$ref": "#/$defs/control_id"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "warn",
              "skipped",
              "waived"
            ]
          },
          "skipped_reason": {
            "type": "string",
            "minLength": 1
          },
          "waiver_id": {
            "type": "string",
            "pattern": "^WV-[0-9]+$"
          },
          "compensating_control": {
            "$ref": "#/$defs/control_id"
          },
          "evidence_ref": {
            "$ref": "#/$defs/evidence_ref"
          },
          "detail": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "status": {
                  "enum": [
                    "pass",
                    "fail"
                  ]
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "required": [
                "evidence_ref"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "status": {
                  "const": "skipped"
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "required": [
                "skipped_reason"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "status": {
                  "const": "waived"
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "required": [
                "waiver_id",
                "compensating_control",
                "evidence_ref"
              ]
            }
          }
        ]
      }
    },
    "protected_oracle_revision": {
      "type": "string"
    },
    "verdict": {
      "enum": [
        "pass",
        "fail",
        "blocked"
      ]
    },
    "trusted_context": {
      "$ref": "urn:a360:harness:schema:trusted-context:1.8"
    }
  },
  "allOf": [
    {
      "$comment": "INV-AR-1 (P0-3): pass forbids any fail or skipped gate.",
      "if": {
        "properties": {
          "verdict": {
            "const": "pass"
          }
        },
        "required": [
          "verdict"
        ]
      },
      "then": {
        "required": [
          "gates"
        ],
        "properties": {
          "gates": {
            "not": {
              "contains": {
                "type": "object",
                "required": [
                  "status"
                ],
                "properties": {
                  "status": {
                    "enum": [
                      "fail",
                      "skipped"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "$comment": "INV-AR-2 (P0-1): pass forbids any declared-vs-derived mismatch.",
      "if": {
        "properties": {
          "verdict": {
            "const": "pass"
          }
        },
        "required": [
          "verdict"
        ]
      },
      "then": {
        "properties": {
          "derived_facts": {
            "properties": {
              "declaration_mismatches": {
                "maxItems": 0
              }
            }
          }
        }
      }
    },
    {
      "$comment": "INV-AR-3 (P0-2): a dirty worktree cannot produce a pass verdict.",
      "if": {
        "properties": {
          "verdict": {
            "const": "pass"
          }
        },
        "required": [
          "verdict"
        ]
      },
      "then": {
        "properties": {
          "run": {
            "properties": {
              "git_state": {
                "const": "clean"
              }
            }
          }
        }
      }
    },
    {
      "$comment": "INV-AR-4 (P0-1): derived dependency_changed=true requires a CH-04 gate result to exist.",
      "if": {
        "properties": {
          "derived_facts": {
            "properties": {
              "dependency_changed": {
                "const": true
              }
            },
            "required": [
              "dependency_changed"
            ]
          }
        },
        "required": [
          "derived_facts"
        ]
      },
      "then": {
        "properties": {
          "gates": {
            "contains": {
              "type": "object",
              "required": [
                "control_id"
              ],
              "properties": {
                "control_id": {
                  "const": "CH-04"
                }
              }
            }
          }
        }
      }
    },
    {
      "$comment": "P0-1: a non-authoritative (local) context can never produce a pass verdict.",
      "if": {
        "properties": {
          "verdict": {
            "const": "pass"
          }
        },
        "required": [
          "verdict"
        ]
      },
      "then": {
        "properties": {
          "trusted_context": {
            "properties": {
              "mode": {
                "const": "authoritative"
              }
            },
            "required": [
              "mode"
            ]
          }
        }
      }
    },
    {
      "$comment": "P1-1: a silent install hit forces dependency_changed=true.",
      "if": {
        "properties": {
          "derived_facts": {
            "properties": {
              "silent_install_hits": {
                "minItems": 1
              }
            },
            "required": [
              "silent_install_hits"
            ]
          }
        },
        "required": [
          "derived_facts"
        ]
      },
      "then": {
        "properties": {
          "derived_facts": {
            "properties": {
              "dependency_changed": {
                "const": true
              }
            }
          }
        }
      }
    },
    {
      "$comment": "P1-2: an unreadable in-scope file is indeterminate; it can never yield a pass.",
      "if": {
        "properties": {
          "verdict": {
            "const": "pass"
          }
        },
        "required": [
          "verdict"
        ]
      },
      "then": {
        "properties": {
          "derived_facts": {
            "properties": {
              "unreadable_scanned_paths": {
                "maxItems": 0
              }
            }
          }
        }
      }
    }
  ]
}
